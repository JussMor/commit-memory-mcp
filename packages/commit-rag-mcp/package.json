{
  "name": "@jussmor/commit-memory-mcp-surreal",
  "version": "0.2.4",
  "mcpName": "io.github.jussmor/commit-memory-surreal",
  "description": "Commit-aware MCP with SurrealDB-backed traceability, async team coordination, and business knowledge tools",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JussMor/commit-memory-mcp.git"
  },
  "homepage": "https://github.com/JussMor/commit-memory-mcp",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "commit-memory-mcp-surreal": "./dist/index.js"
  },
  "files": [
    "dist",
    "server.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:tools": "node test-tools-smoke.mjs",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@xenova/transformers": "^2.17.2",
    "surrealdb": "^2.0.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
