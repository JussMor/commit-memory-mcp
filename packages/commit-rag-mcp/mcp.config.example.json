{
  "servers": {
    "commit-memory-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@jussmor/commit-memory-mcp"
      ],
      "env": {
        "COMMIT_RAG_REPO": "/absolute/path/to/target/repo",
        "COMMIT_RAG_DB": "/absolute/path/to/target/repo/.commit-rag.db",
        "COMMIT_RAG_LIMIT": "800",
        "OLLAMA_BASE_URL": "http://127.0.0.1:11434",
        "OLLAMA_EMBED_MODEL": "nomic-embed-text",
        "COPILOT_TOKEN": "",
        "COPILOT_MODEL": "gpt-4o-mini",
        "COPILOT_BASE_URL": "https://api.githubcopilot.com"
      }
    }
  }
}
