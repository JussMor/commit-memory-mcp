{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.jussmor/commit-memory",
  "description": "Commit-aware MCP server with SurrealDB-backed traceability, PR context sync, and business knowledge tools.",
  "repository": {
    "url": "https://github.com/JussMor/commit-memory-mcp",
    "source": "github"
  },
  "version": "2.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@jussmor/commit-memory-mcp",
      "version": "2.0.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "environmentVariables": [
        {
          "name": "SURREAL_URL",
          "description": "SurrealDB WebSocket URL (wss:// for cloud, ws:// for local).",
          "format": "string",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "SURREAL_USER",
          "description": "SurrealDB root username.",
          "format": "string",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "SURREAL_PASS",
          "description": "SurrealDB root password.",
          "format": "string",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "SURREAL_NS",
          "description": "SurrealDB namespace.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "SURREAL_DB",
          "description": "SurrealDB database name.",
          "format": "string",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ]
}