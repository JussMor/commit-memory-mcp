{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/index.ts",
    "src/types.ts",
    "src/cli/**/*.ts",
    "src/db/**/*.ts",
    "src/layers/**/*.ts",
    "src/search/embeddings.ts",
    "src/tools/**/*.ts"
  ]
}
