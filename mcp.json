{
  "mcpServers": {
    "commit-rag": {
      "command": "npx",
      "args": ["commit-rag-mcp"],
      "env": {
        "COMMIT_RAG_REPO": "${workspaceFolder}",
        "COMMIT_RAG_DB": "${workspaceFolder}/.commit-rag.db",
        "COMMIT_RAG_LIMIT": "400",
        "OLLAMA_BASE_URL": "http://127.0.0.1:11434",
        "OLLAMA_EMBED_MODEL": "nomic-embed-text"
      },
      "disabled": false,
      "alwaysAllow": []
    }
  }
}
